{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "Tenant organization",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string", "description": "Unique join code" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "logoUrl": { "type": "string" },
        "bannerUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "code", "createdAt", "ownerId"]
    },
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "unitId": { "type": "string", "description": "ID of the factory, warehouse, or outlet they belong to" },
        "companyId": { "type": "string" }
      },
      "required": ["uid", "email", "name", "roles", "companyId"]
    },
    "Factory": {
      "title": "Factory",
      "description": "Food production facility",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "location", "companyId"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Storage facility for raw materials or finished goods",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "factoryId": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "location", "companyId"]
    },
    "SalesOutlet": {
      "title": "SalesOutlet",
      "description": "Retail or wholesale distribution point",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "location", "companyId"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Provider of raw materials",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "contact", "companyId"]
    },
    "RawMaterial": {
      "title": "RawMaterial",
      "description": "Input for food production",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "unit": { "type": "string", "enum": ["kg", "liter", "unit", "bag"] },
        "companyId": { "type": "string" }
      },
      "required": ["name", "unit", "companyId"]
    },
    "Product": {
      "title": "Product",
      "description": "Finished food product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "packageSize": { "type": "string" },
        "unit": { "type": "string" },
        "price": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "category", "packageSize", "price", "companyId"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Stock levels in a specific unit",
      "type": "object",
      "properties": {
        "unitId": { "type": "string" },
        "itemId": { "type": "string" },
        "itemType": { "type": "string", "enum": ["raw", "product"] },
        "quantity": { "type": "number" },
        "batchNumber": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      },
      "required": ["unitId", "itemId", "itemType", "quantity", "companyId"]
    },
    "PurchaseOrder": {
      "title": "PurchaseOrder",
      "description": "Order for raw materials",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "factoryId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "shipped", "received", "cancelled"] },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      },
      "required": ["supplierId", "factoryId", "status", "totalAmount", "companyId"]
    },
    "ProductionPlan": {
      "title": "ProductionPlan",
      "description": "Hierarchical manufacturing plan (Annual -> Quarterly -> Monthly)",
      "type": "object",
      "properties": {
        "factoryId": { "type": "string" },
        "productId": { "type": "string" },
        "year": { "type": "number" },
        "totalQuantity": { "type": "number" },
        "quarterlyPlans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "quarter": { "type": "string", "enum": ["Q1", "Q2", "Q3", "Q4"] },
              "quantity": { "type": "number" },
              "monthlyPlans": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "month": { "type": "number" },
                    "quantity": { "type": "number" }
                  },
                  "required": ["month", "quantity"]
                }
              }
            },
            "required": ["quarter", "quantity", "monthlyPlans"]
          }
        },
        "status": { "type": "string", "enum": ["planned", "in_progress", "completed"] },
        "companyId": { "type": "string" }
      },
      "required": ["factoryId", "productId", "year", "totalQuantity", "quarterlyPlans", "status", "companyId"]
    },
    "ProductionRun": {
      "title": "ProductionRun",
      "description": "Actual manufacturing execution record",
      "type": "object",
      "properties": {
        "factoryId": { "type": "string" },
        "productId": { "type": "string" },
        "recipeId": { "type": "string" },
        "quantity": { "type": "number" },
        "quantityProduced": { "type": "number" },
        "status": { "type": "string", "enum": ["planned", "in_progress", "completed"] },
        "startDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      },
      "required": ["factoryId", "productId", "quantity", "status", "startDate", "companyId"]
    },
    "SalesOrder": {
      "title": "SalesOrder",
      "description": "Customer order for products",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "outletId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "ready_to_ship", "shipped", "delivered", "cancelled"] },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "companyId": { "type": "string" }
      },
      "required": ["outletId", "status", "totalAmount", "companyId"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Staff member details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "department": { "type": "string" },
        "role": { "type": "string" },
        "salary": { "type": "number" },
        "factoryId": { "type": "string" },
        "hireDate": { "type": "string", "format": "date" },
        "companyId": { "type": "string" }
      },
      "required": ["name", "email", "department", "role", "companyId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing record",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "orderType": { "type": "string", "enum": ["purchase", "sales"] },
        "amount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["draft", "issued", "paid", "overdue", "cancelled"] },
        "companyId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "orderType", "amount", "dueDate", "status", "companyId", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment record",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string", "enum": ["cash", "bank_transfer", "check", "credit_card"] },
        "companyId": { "type": "string" }
      },
      "required": ["invoiceId", "amount", "paymentDate", "paymentMethod", "companyId"]
    },
    "FinancialPlan": {
      "title": "FinancialPlan",
      "description": "Yearly financial plan with quarterly targets",
      "type": "object",
      "properties": {
        "year": { "type": "number" },
        "quarter": { "type": "string", "enum": ["Q1", "Q2", "Q3", "Q4"] },
        "targetRevenue": { "type": "number" },
        "targetExpense": { "type": "number" },
        "companyId": { "type": "string" }
      },
      "required": ["year", "quarter", "targetRevenue", "targetExpense", "companyId"]
    }
  },
  "firestore": {
    "companies": { "schema": "Company", "description": "Tenant organizations" },
    "users": { "schema": "User", "description": "System users" },
    "factories": { "schema": "Factory", "description": "Production units" },
    "warehouses": { "schema": "Warehouse", "description": "Storage units" },
    "outlets": { "schema": "SalesOutlet", "description": "Sales units" },
    "suppliers": { "schema": "Supplier", "description": "Raw material providers" },
    "rawMaterials": { "schema": "RawMaterial", "description": "Inventory items (raw)" },
    "products": { "schema": "Product", "description": "Inventory items (finished)" },
    "inventory": { "schema": "Inventory", "description": "Stock records" },
    "purchaseOrders": { "schema": "PurchaseOrder", "description": "Procurement records" },
    "productionPlans": { "schema": "ProductionPlan", "description": "Manufacturing records" },
    "productionRuns": { "schema": "ProductionRun", "description": "Actual manufacturing execution records" },
    "salesOrders": { "schema": "SalesOrder", "description": "Sales records" },
    "employees": { "schema": "Employee", "description": "Workforce records" },
    "invoices": { "schema": "Invoice", "description": "Billing records" },
    "payments": { "schema": "Payment", "description": "Payment records" },
    "financialPlans": { "schema": "FinancialPlan", "description": "Financial plans" }
  }
}
